generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Selecao {
  id          Int         @id @default(autoincrement())
  pais        String      @db.VarChar(100)
  continente  String      @db.VarChar(100)
  treinador   String      @db.VarChar(100)
  numCopas    Int?        @db.SmallInt
  jogadores   Jogador[]
  @@map("selecoes")
}

model Jogador {
  id          Int         @id @default(autoincrement())
  nome        String      @db.VarChar(100)
  posicao     Posicao
  selecaoId   Int
  dataNasc    DateTime
  numCamisa   Int         @db.SmallInt
  selecao     Selecao     @relation(fields: [selecaoId], references: [id])
  @@map("jogadores")
}

enum Posicao {
  Goleiro
  Lateral
  Zagueiro
  Meio_Campo
  Atacante
}